{
  "name": "battlechallenge",
  "version": "0.1.0",
  "description": "The open-source benchmarking system that compares agentic AI frameworks head-to-head on standardized tasks.",
  "type": "module",
  "bin": {
    "battle": "./dist/cli/index.js",
    "battlechallenge": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ --ext .ts",
    "typecheck": "tsc --noEmit",
    "start": "node dist/cli/index.js"
  },
  "keywords": [
    "benchmark",
    "ai",
    "agents",
    "frameworks",
    "comparison",
    "leaderboard"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "yaml": "^2.4.0",
    "zod": "^3.23.0"
  }
}
